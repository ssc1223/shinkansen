{
  "name": "shinkansen-tests",
  "version": "0.0.1",
  "private": true,
  "description": "Shinkansen Chrome Extension 的 Playwright 自動化測試 harness",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:regression": "playwright test test/regression/",
    "test:unit": "playwright test test/unit/",
    "test:version": "playwright test test/version-check.spec.js",
    "test:jest": "jest --config jest.config.cjs",
    "test:all": "playwright test && jest --config jest.config.cjs",
    "debug": "node tools/debug-harness.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "jest": "^29.7.0",
    "jsdom": "^25.0.1"
  }
}
